# Halo Blog Configuration
HALO_DEBUG=false
HALO_SECRET_KEY=change-this-to-a-random-string-in-production
HALO_HOST=0.0.0.0
HALO_PORT=8000

# Database
HALO_DATABASE_URL=sqlite+aiosqlite:///./data/blog.db

# Admin
HALO_ADMIN_USERNAME=admin
HALO_ADMIN_PASSWORD=admin123

# Blog
HALO_BLOG_TITLE=My Blog
HALO_BLOG_SUBTITLE=A personal blog powered by Halo Blog
HALO_BLOG_FOOTER=© 2026 Halo Blog. All rights reserved.
HALO_POSTS_PER_PAGE=10

# Upload
HALO_UPLOAD_DIR=uploads
HALO_MAX_UPLOAD_SIZE=10485760
